# ── Python cache ───────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
.pytest_cache/

# ── Virtual environments ───────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Secrets — NEVER in image ──────────────────────────────
